generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./library.db"
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

model Student {
  id          Int    @id @default(autoincrement())
  fullName    String
  admissionNo String @unique
  className   String

  borrowings Borrowing[]
}

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  author      String
  category    String
  isbn        String   @unique
  publisher   String?
  publishedAt Int?
  quantity    Int
  available   Int

  borrowings Borrowing[]
}


model Borrowing {
  id         Int       @id @default(autoincrement())

  studentId  Int
  bookId     Int

  borrowDate DateTime
  dueDate    DateTime
  returnDate DateTime?

  status String

  student Student @relation(fields: [studentId], references: [id])
  book Book @relation(fields: [bookId], references: [id])
}